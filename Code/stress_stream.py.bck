    #print(kin_ode_zs)
    #print(kin_ode_zb)

    # Minus sign because we moved these terms to the rhs
    kin_bc_rhs = (kin_ode_zs-kin_ode_zb)
    #print(kin_ode_zb)

    kin_bc = k*((psi(k,z=zs))-(psi(k,z=zb)))
    

    # Part of C31 without S2 (proportional to A^5)
    C51=solve(A,stress_bc_rhs)
    #print(C51)
 

    # Part of C31 with S2 (propotional to A^3)
    C51_S2 = solve(A,stress_bc_rhs_S2)
    # Part of C31 with S4 (propotional to A)
    C51_S4 = solve(A,stress_bc_rhs_S4)
    #print(C31_S4)

    # Terms in dAdt proportional to A^5 (negative kin_bc_rhs because we move it to the rhs)
    dAdt_5=(np.dot(C51.T,kin_bc)-kin_bc_rhs)[0]
    # Terms in dAdt proportional to A^3
    dAdt_3=(np.dot(C51_S2.T,kin_bc))[0]
    # Terms in dAdt proportional to A
    dAdt_1=(np.dot(C51_S4.T,kin_bc))[0]

    #print(kin_bc_rhs - np.dot(C51.T,kin_bc))
    return [dAdt_1,dAdt_3,dAdt_5]





    
