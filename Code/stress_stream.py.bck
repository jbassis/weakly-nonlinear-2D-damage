    kin_ode_zb =-5*(b11**2 + (72*b20)/5 + (48*b22)/5)*b11**2*k*h11.diff_psi(k,z=zb,deriv=3)/192 - h22.diff_psi(2*k,z=zb,deriv=3)*k*b11**3/6 \
