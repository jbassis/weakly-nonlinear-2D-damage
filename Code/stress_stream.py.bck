                                         + (-2*s40 - s42)*(-4*xi*S0) + 2*tau_xx_40)*s11 - (-4*xi*S0)*(s33)*s22 )/2 + (-tau_xx_11s*k**3*s11**2*s22/8 
                                                                                                                      + (3*tau_xx_11s*k**3*s11**2*s20)/4 
