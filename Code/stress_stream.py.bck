    kin_ode_zs = -5*(s11**2 + (72*s20)/5 + (48*s22)/5)*s11**2*k*h11.diff_psi(k,z=zs,deriv=3)/192 - h22.diff_psi(2*k,z=zs,deriv=3)*k*s11**3/6 \
